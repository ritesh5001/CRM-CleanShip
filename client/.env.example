# Client (Vite) — only variables prefixed with VITE_ are exposed to the browser.

# Base URL of the CRM API (including the /api/v1 path).
# Leave UNSET for local dev: the Vite dev server proxies /api -> http://localhost:5050.
# Set this only when pointing the built client at a deployed API, e.g.:
# VITE_API_URL=https://api.cleanship.com/api/v1
VITE_API_URL=
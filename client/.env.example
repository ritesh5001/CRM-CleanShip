# Client (Vite) — only variables prefixed with VITE_ are exposed to the browser.

# Base URL of the CRM API. You may pass either the origin or the full /api/v1
# path — the client adds /api/v1 automatically if it's missing.
# Leave UNSET for local dev: the Vite dev server proxies /api -> http://localhost:5050.
# Production example (both of these work):
#   VITE_API_URL=https://crm-cleanship.onrender.com
#   VITE_API_URL=https://crm-cleanship.onrender.com/api/v1
VITE_API_URL=
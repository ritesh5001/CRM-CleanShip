# Server
# Note: macOS uses port 5000 for AirPlay Receiver, so we default to 5050.
PORT=5050
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/crm_cleanship

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS — client origin
CLIENT_ORIGIN=http://localhost:5173

# Keep-alive self-ping (prevents Render free tier from sleeping after ~15 min idle).
# On Render this is set automatically via RENDER_EXTERNAL_URL; only set SELF_URL to
# override. Leave blank locally to disable the self-ping.
# SELF_URL=https://your-service.onrender.com

# Twilio browser calling is configured from the in-app admin panel
# (Settings → Integrations), NOT here. The only Twilio-related env var is the
# fallback public URL Twilio uses to reach our recording/status webhooks — and
# even that can be set from the panel ("Public server URL"). Use an ngrok URL for
# local testing if you don't set it in the panel.
# PUBLIC_SERVER_URL=https://your-server.example.com

# Initial superadmin (used by `npm run seed`)
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@cleanship.com
SUPERADMIN_PASSWORD=Admin@12345
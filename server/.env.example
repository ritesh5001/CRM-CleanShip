# Server
# Note: macOS uses port 5000 for AirPlay Receiver, so we default to 5050.
PORT=5050
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/crm_cleanship

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS — client origin
CLIENT_ORIGIN=http://localhost:5173

# Initial superadmin (used by `npm run seed`)
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@cleanship.com
SUPERADMIN_PASSWORD=Admin@12345